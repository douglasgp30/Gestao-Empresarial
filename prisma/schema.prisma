// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ma/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campanha {
  id          Int      @id @default(autoincrement()) // CodigoCampanha
  nome        String   // NomeCampanha (obrigatório)
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos LancamentoCaixa[]

  @@map("campanhas")
}

model Descricao {
  id          Int      @id @default(autoincrement()) // CodigoDescricao
  nome        String   // Descrição (obrigatório)
  categoria   String?
  tipo        String   @default("receita") // "receita" ou "despesa"
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos    LancamentoCaixa[]
  subdescricoes  Subdescricao[]

  @@map("descricoes")
}

// Tabela unificada para Descrições e Categorias
model DescricaoECategoria {
  id          Int      @id @default(autoincrement())
  nome        String   // Nome da descrição ou categoria
  tipo        String   // "receita" ou "despesa"
  tipoItem    String   // "descricao" ou "categoria"
  categoria   String?  // Categoria pai (apenas para descrições)
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  // Relacionamentos com Caixa
  lancamentosCaixa    LancamentoCaixa[]
  subdescricoes       Subdescricao[]

  // Relacionamentos com Contas
  contasLancamentos   ContaLancamento[] @relation("DescricaoCategoria")

  @@map("descricoes_e_categorias")
  @@index([tipo])
  @@index([tipoItem])
  @@index([ativo])
}

// Tabela unificada para Cidades e Setores (baseada no padrão de DescricaoECategoria)
model LocalizacaoGeografica {
  id          Int      @id @default(autoincrement())
  nome        String   // Nome da cidade ou setor
  tipoItem    String   // "cidade" ou "setor"
  cidade      String?  // Cidade pai (apenas para setores)
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos  LancamentoCaixa[]
  agendamentos Agendamento[]
  contas       ContaLancamento[]

  @@map("localizacoes_geograficas")
  @@index([tipoItem])
  @@index([ativo])
  @@index([cidade])
}

model Subdescricao {
  id          Int      @id @default(autoincrement()) // CodigoSubdescricao
  nome        String   // Subdescricao (obrigatório)
  descricaoId Int      // CodigoDescricao (FK obrigatório)
  dataCriacao DateTime @default(now())

  // Support for unified table
  descricaoECategoriaId Int? // FK to unified table

  // Relacionamentos
  descricao   Descricao         @relation(fields: [descricaoId], references: [id])
  lancamentos LancamentoCaixa[]
  descricaoECategoria DescricaoECategoria? @relation(fields: [descricaoECategoriaId], references: [id])

  @@map("subdescricoes")
}

model FormaPagamento {
  id          Int      @id @default(autoincrement()) // CodigoForma
  nome        String   // FormaPagamento (obrigatório)
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos    LancamentoCaixa[]
  contasContas   ContaLancamento[] @relation("FormaPagamentoContas")

  @@map("formas_pagamento")
}

model Cliente {
  id                 Int      @id @default(autoincrement()) // CodigoCliente
  nome               String   // Nome do cliente (obrigatório)
  cpf                String?  @unique // CPF do cliente (opcional)
  telefonePrincipal  String   // Telefone principal (obrigatório)
  telefoneSecundario String?  // Telefone secundário (opcional)
  email              String?  @unique // E-mail (opcional)
  cep                String?  // CEP (opcional)
  logradouro         String?  // Preenchido automaticamente a partir do CEP
  complemento        String?  // Complemento do endereço (opcional)
  dataCriacao        DateTime @default(now())

  // Relacionamentos
  agendamentos   Agendamento[]
  lancamentos    LancamentoCaixa[]
  contasReceber  ContaLancamento[] @relation("ClienteContas")

  @@map("clientes")
  @@index([cpf])
  @@index([email])
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String?
  dataCriacao DateTime @default(now())

  // Relacionamentos
  contasPagar ContaLancamento[] @relation("FornecedorContas")

  @@map("fornecedores")
}

model Categoria {
  id          Int      @id @default(autoincrement())
  nome        String
  tipo        String   // "receita" ou "despesa"
  dataCriacao DateTime @default(now())

  // Relacionamentos
  contas ContaLancamento[]

  @@map("categorias")
}

model Funcionario {
  id                Int      @id @default(autoincrement()) // CodigoTecnico
  nome              String   // NomeTecnico (obrigatório)
  percentualServico Float?   // PercentualServico (obrigatório)
  percentualComissao Float?  // Percentual de comissão do técnico
  ehTecnico         Boolean  @default(false) // Indica se o funcionário é técnico
  email             String?  @unique
  telefone          String?
  cargo             String?
  salario           Float?
  temAcessoSistema  Boolean  @default(false)
  tipoAcesso        String?  // "Administrador", "Operador", "Técnico"
  login             String?  @unique
  senha             String?
  permissoes        String? // JSON das permissões
  registraPonto     Boolean  @default(false) // Define se o funcionário pode usar o controle de ponto
  dataCriacao       DateTime @default(now())

  // Relacionamentos
  lancamentos           LancamentoCaixa[]
  agendamentos          Agendamento[]
  contasLancamento      ContaLancamento[] @relation("FuncionarioLancamento")
  contasPagamento       ContaLancamento[] @relation("FuncionarioPagamento")
  contasCobranca        ContaLancamento[] @relation("FuncionarioCobranca")
  pontos                Ponto[] // Relacionamento com registros de ponto

  @@map("funcionarios")
  @@index([email])
  @@index([temAcessoSistema])
  @@index([tipoAcesso])
  @@index([registraPonto])
}


model LancamentoCaixa {
  id                Int      @id @default(autoincrement()) // CodLançamentoCX
  dataHora          DateTime // Data e hora do lançamento
  valor             Float    // Valor do lançamento (obrigatório)
  valorRecebido     Float?   // Valor efetivamente recebido (obrigatório para cartão)
  valorLiquido      Float?   // Valor líquido ap��s descontos
  comissao          Float?   // Comissão do técnico
  imposto           Float?   // Impostos/taxas
  observacoes       String?  // Observações do lançamento
  numeroNota        String?  // Número da nota fiscal
  arquivoNota       String?  // Arquivo da nota fiscal
  tipo              String   // "receita" ou "despesa" (obrigatório)
  dataCriacao       DateTime @default(now())

  // Chaves estrangeiras obrigatórias
  descricaoId       Int      // Puxa da tabela Descrição
  formaPagamentoId  Int      // Puxa da tabela Forma de Pagamento

  // Chaves estrangeiras opcionais
  subdescricaoId    Int?     // Puxa da tabela Subdescrição
  funcionarioId     Int?     // Puxa da tabela Técnicos
  campanhaId        Int?     // Puxa da tabela Campanhas
  clienteId         Int?     // Puxa da tabela Clientes
  localizacaoId     Int?     // Puxa da tabela Localizações Geográficas

  // Unified descriptions and categories
  descricaoECategoriaId Int? // FK to unified table

  // Relacionamentos
  descricao      Descricao      @relation(fields: [descricaoId], references: [id])
  formaPagamento FormaPagamento @relation(fields: [formaPagamentoId], references: [id])
  subdescricao   Subdescricao?  @relation(fields: [subdescricaoId], references: [id])
  funcionario    Funcionario?   @relation(fields: [funcionarioId], references: [id])
  campanha       Campanha?      @relation(fields: [campanhaId], references: [id])
  cliente        Cliente?       @relation(fields: [clienteId], references: [id])
  descricaoECategoria DescricaoECategoria? @relation(fields: [descricaoECategoriaId], references: [id])
  localizacao    LocalizacaoGeografica? @relation(fields: [localizacaoId], references: [id])

  @@map("lancamentos_caixa")
  @@index([dataHora])
  @@index([tipo], map: "lancamentos_caixa_tipo_idx")
  @@index([funcionarioId])
  @@index([clienteId])
}

// Enhanced ContaLancamento model with complete Brazilian accounts payable/receivable features
model ContaLancamento {
  // Primary Key
  id                    Int      @id @default(autoincrement()) // BIGSERIAL PK

  // Basic Information
  dataLancamento        DateTime @default(now()) // TIMESTAMP - Creation date
  dataVencimento        DateTime // DATE - Due date
  dataPagamento         DateTime? // TIMESTAMP - Payment date (conditional)
  dataOperacao          DateTime? // DATE - Operation date (when service was provided)

  // Document Information
  numeroDocumento       String?  // Document/Invoice number
  numeroNF              String?  // Tax invoice number (Nota Fiscal)
  numeroNFSe            String?  // Service invoice number
  serieDocumento        String?  // Document series
  chaveNFe              String?  // NFe access key

  // Installment Information
  numeroMesParcela      Int?     // Installment number (e.g., 1, 2, 3...)
  totalParcelas         Int?     // Total installments (e.g., 12)
  descricaoParcela      String?  // Installment description (e.g., "3/12")
  contrato              String?  // Contract number for installments

  // Amount Fields (using Float for SQLite compatibility)
  valorOriginal         Float    // Original amount
  valorDesconto         Float?   @default(0) // Discount amount
  valorAcrescimo        Float?   @default(0) // Additional charges
  valorJuros            Float?   @default(0) // Interest amount
  valorMulta            Float?   @default(0) // Penalty amount
  valorLiquido          Float    // Net amount after calculations
  valorPago             Float?   @default(0) // Amount actually paid
  valorRestante         Float?   @default(0) // Remaining amount

  // Tax Information
  valorIR               Float?   @default(0) // Income tax withheld
  valorISS              Float?   @default(0) // ISS tax
  valorPIS              Float?   @default(0) // PIS tax
  valorCOFINS           Float?   @default(0) // COFINS tax
  valorCSLL             Float?   @default(0) // CSLL tax
  valorINSS             Float?   @default(0) // INSS tax
  baseCalculoIR         Float?   // IR calculation base

  // Status Management
  status                String   @default("pendente") // "pendente", "pago", "parcial", "vencido", "cancelado", "protestado"
  statusCobranca        String?  // "em_cobranca", "juridico", "acordo", "parcelado"
  prioridadePagamento   String?  @default("normal") // "baixa", "normal", "alta", "urgente"

  // Entity Relationships
  codigoCliente         Int?     // BIGINT FK clientes(id) - Conditional
  codigoFornecedor      Int?     // BIGINT FK fornecedores(id) - Conditional
  tipo                  String   // ENUM('receber','pagar')

  // Payment Information
  formaPagamentoId      Int?     // SMALLINT FK formas_pagamento(id) - Conditional
  contaBancariaId       Int?     // Bank account used for payment
  agenciaBancaria       String?  // Bank branch
  numeroConta           String?  // Account number
  digitoConta           String?  // Account digit
  nomeBanco             String?  // Bank name
  codigoBanco           String?  // Bank code

  // Cost Center and Project Tracking
  centroCustoId         Int?     // Cost center ID
  projetoId             Int?     // Project ID
  departamentoId        Int?     // Department ID
  categoriaId           Int?     // SMALLINT FK categorias(id)
  subcategoriaId        Int?     // Subcategory ID

  // Unified descriptions and categories
  descricaoECategoriaId Int?     // FK to unified table

  // Geographic Information
  localizacaoId         Int?     // FK to localizacao geografica

  // Recurring Information
  ehRecorrente          Boolean  @default(false) // Is recurring
  tipoRecorrencia       String?  // "mensal", "trimestral", "semestral", "anual"
  proximoVencimento     DateTime? // Next due date for recurring
  contaOrigemId         Int?     // Original account for recurring copies

  // Additional Information
  observacoes           String?  // TEXT - Comments
  observacoesInternas   String?  // Internal comments
  motivoCancelamento    String?  // Cancellation reason
  anexos                String?  // JSON with attached files
  tags                  String?  // JSON with tags


  // Responsible Information
  funcionarioLancamento Int?     // Employee who created the record
  funcionarioPagamento  Int?     // Employee who processed payment
  funcionarioCobranca   Int?     // Employee responsible for collection

  // Integration Fields
  codigoExterno         String?  // External system code
  sistemaOrigem         String?  // Origin system
  sincronizado          Boolean  @default(false) // Sync status

  // Audit Trail
  dataCriacao           DateTime @default(now()) // Creation timestamp
  dataAlteracao         DateTime @updatedAt // Last update timestamp
  usuarioCriacao        Int?     // User who created
  usuarioAlteracao      Int?     // User who last updated
  versao                Int      @default(1) // Version control
  ativo                 Boolean  @default(true) // Soft delete flag

  // Workflow Information
  aprovado              Boolean  @default(false) // Approval status
  dataAprovacao         DateTime? // Approval date
  usuarioAprovacao      Int?     // User who approved
  workflow              String?  // JSON with workflow data

  // Relationships
  cliente               Cliente?        @relation("ClienteContas", fields: [codigoCliente], references: [id])
  fornecedor            Fornecedor?     @relation("FornecedorContas", fields: [codigoFornecedor], references: [id])
  formaPagamento        FormaPagamento? @relation("FormaPagamentoContas", fields: [formaPagamentoId], references: [id])
  categoria             Categoria?      @relation(fields: [categoriaId], references: [id])
  funcionarioLanc       Funcionario?    @relation("FuncionarioLancamento", fields: [funcionarioLancamento], references: [id])
  funcionarioPag        Funcionario?    @relation("FuncionarioPagamento", fields: [funcionarioPagamento], references: [id])
  funcionarioCob        Funcionario?    @relation("FuncionarioCobranca", fields: [funcionarioCobranca], references: [id])
  contaOrigem           ContaLancamento? @relation("ContaRecorrente", fields: [contaOrigemId], references: [id])
  contasRecorrentes     ContaLancamento[] @relation("ContaRecorrente")
  descricaoECategoria   DescricaoECategoria? @relation("DescricaoCategoria", fields: [descricaoECategoriaId], references: [id])
  localizacao           LocalizacaoGeografica? @relation(fields: [localizacaoId], references: [id])

  // Indexes for performance
  @@map("contas_lancamentos_enhanced")
  @@index([dataVencimento])
  @@index([dataPagamento])
  @@index([tipo], map: "contas_lancamentos_tipo_idx")
  @@index([status])
  @@index([codigoCliente])
  @@index([codigoFornecedor])
  @@index([formaPagamentoId])
  @@index([centroCustoId])
  @@index([projetoId])
  @@index([numeroDocumento])
  @@index([numeroNF])
  @@index([ehRecorrente])
  @@index([proximoVencimento])
  @@index([dataCriacao])
  @@index([ativo])
  @@index([aprovado])
  @@index([statusCobranca])
  @@index([prioridadePagamento])
}

// Supporting models for the enhanced accounts system

model CentroCusto {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nome        String
  descricao   String?
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  @@map("centros_custo")
}

model Projeto {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nome        String
  descricao   String?
  dataInicio  DateTime?
  dataFim     DateTime?
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  @@map("projetos")
}

model Departamento {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique
  nome        String
  descricao   String?
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  @@map("departamentos")
}

model ContaBancaria {
  id          Int      @id @default(autoincrement())
  banco       String
  agencia     String
  conta       String
  digito      String?
  tipo        String   // "corrente", "poupanca", "aplicacao"
  descricao   String?
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  @@map("contas_bancarias")
}

// Manter tabela antiga para compatibilidade temporária
model Conta {
  id            Int      @id @default(autoincrement())
  tipo          String // "pagar" ou "receber"
  descricao     String
  valor         Float
  dataVencimento DateTime
  dataPagamento DateTime?
  status        String   @default("pendente") // "pendente", "pago", "atrasado"
  observacoes   String?
  categoria     String?
  dataCriacao   DateTime @default(now())

  @@map("contas")
  @@index([dataVencimento])
  @@index([status])
  @@index([tipo])
}

model Agendamento {
  id          Int      @id @default(autoincrement())
  data        DateTime
  horario     String
  servico     String
  observacoes String?
  status      String   @default("agendado") // "agendado", "realizado", "cancelado"
  dataCriacao DateTime @default(now())

  // Chaves estrangeiras
  clienteId     Int
  funcionarioId Int?
  localizacaoId Int?

  // Relacionamentos
  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  funcionario Funcionario? @relation(fields: [funcionarioId], references: [id])
  localizacao LocalizacaoGeografica? @relation(fields: [localizacaoId], references: [id])

  @@map("agendamentos")
}

model Configuracao {
  id           Int      @id @default(autoincrement())
  chave        String   @unique
  valor        String
  descricao    String?
  dataAlteracao DateTime @default(now())

  @@map("configuracoes")
}

// Sistema de Auditoria - Registra todas as ações dos usuários
model LogAuditoria {
  id            Int      @id @default(autoincrement())

  // Informações da ação
  acao          String   // Tipo de ação: "CREATE", "UPDATE", "DELETE", "LOGIN", etc.
  entidade      String   // Tabela/entidade afetada: "lancamentos_caixa", "funcionarios", etc.
  entidadeId    String?  // ID do registro afetado

  // Dados da ação
  dadosAntigos  String?  // JSON com dados antes da alteração
  dadosNovos    String?  // JSON com dados após a alteração
  descricao     String?  // Descrição da ação em linguagem natural

  // Informações do usuário
  usuarioId     String   // ID do usuário que executou a ação
  usuarioNome   String   // Nome do usuário (para facilitar consultas)
  usuarioLogin  String?  // Login do usuário

  // Informações técnicas
  ip            String?  // IP de onde veio a requisição
  userAgent     String?  // Browser/dispositivo usado
  sessaoId      String?  // ID da sessão

  // Metadados
  sucesso       Boolean  @default(true) // Se a ação foi bem-sucedida
  mensagemErro  String?  // Mensagem de erro, se houver
  duracaoMs     Int?     // Tempo de execução em millisegundos

  // Timestamp
  dataHora      DateTime @default(now())

  @@map("logs_auditoria")
  @@index([usuarioId])
  @@index([entidade])
  @@index([acao])
  @@index([dataHora])
}

// Sistema de Controle de Ponto
model Ponto {
  id                  Int      @id @default(autoincrement())
  funcionarioId       Int      // FK para Funcionario
  data                DateTime @db.date // Data do ponto (sem horário)
  horaEntrada         DateTime? // Horário de entrada
  horaSaidaAlmoco     DateTime? // Horário de saída para almoço
  horaRetornoAlmoco   DateTime? // Horário de retorno do almoço
  horaSaida           DateTime? // Horário de saída
  observacao          String?  // Observações do registro
  totalHoras          Float?   // Total de horas trabalhadas (calculado)
  horasExtras         Float?   // Horas extras (se houver)
  atraso              Int?     // Minutos de atraso (se houver)
  justificativaAtraso String?  // Justificativa para atraso
  editadoPorAdmin     Boolean  @default(false) // Se foi editado por administrador
  usuarioEdicao       String?  // Usuário que fez a última edição
  dataEdicao          DateTime? // Data da última edição
  dataCriacao         DateTime @default(now())

  // Relacionamentos
  funcionario         Funcionario @relation(fields: [funcionarioId], references: [id])

  @@map("pontos")
  @@index([funcionarioId])
  @@index([data])
  @@index([dataCriacao])
  @@unique([funcionarioId, data]) // Um registro por funcionário por dia
}
