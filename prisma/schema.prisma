// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ma/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campanha {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String?
  ativa       Boolean  @default(true)
  dataInicio  DateTime?
  dataFim     DateTime?
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos LancamentoCaixa[]

  @@map("campanhas")
}

model Descricao {
  id          Int      @id @default(autoincrement())
  nome        String
  categoria   String?
  tipo        String   @default("receita") // "receita" ou "despesa"
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos LancamentoCaixa[]

  @@map("descricoes")
}

model FormaPagamento {
  id          Int      @id @default(autoincrement())
  nome        String
  ativa       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos LancamentoCaixa[]

  @@map("formas_pagamento")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  cpf         String?
  telefone1   String
  telefone2   String?
  email       String?
  endereco    String?
  dataCriacao DateTime @default(now())

  // Relacionamentos
  agendamentos Agendamento[]

  @@map("clientes")
}

model Fornecedor {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String?
  dataCriacao DateTime @default(now())

  @@map("fornecedores")
}

model Funcionario {
  id               Int      @id @default(autoincrement())
  nome             String
  email            String?
  telefone         String?
  cargo            String?
  salario          Float?
  temAcessoSistema Boolean  @default(false)
  login            String?  @unique
  senha            String?
  permissoes       String? // JSON das permissões
  dataCriacao      DateTime @default(now())

  // Relacionamentos
  lancamentos  LancamentoCaixa[]
  agendamentos Agendamento[]

  @@map("funcionarios")
}

model Setor {
  id          Int      @id @default(autoincrement())
  nome        String
  cidade      String
  ativo       Boolean  @default(true)
  dataCriacao DateTime @default(now())

  // Relacionamentos
  lancamentos  LancamentoCaixa[]
  agendamentos Agendamento[]

  @@map("setores")
}

model LancamentoCaixa {
  id                Int      @id @default(autoincrement())
  data              DateTime
  tipo              String // "receita" ou "despesa"
  valor             Float
  valorLiquido      Float?
  comissao          Float?
  imposto           Float?
  valorQueEntrou    Float?
  observacoes       String?
  numeroNota        String?
  arquivoNota       String?
  dataCriacao       DateTime @default(now())

  // Chaves estrangeiras
  descricaoId       Int
  formaPagamentoId  Int
  funcionarioId     Int?
  setorId           Int?
  campanhaId        Int?

  // Relacionamentos
  descricao      Descricao      @relation(fields: [descricaoId], references: [id])
  formaPagamento FormaPagamento @relation(fields: [formaPagamentoId], references: [id])
  funcionario    Funcionario?   @relation(fields: [funcionarioId], references: [id])
  setor          Setor?         @relation(fields: [setorId], references: [id])
  campanha       Campanha?      @relation(fields: [campanhaId], references: [id])

  @@map("lancamentos_caixa")
}

model Conta {
  id            Int      @id @default(autoincrement())
  tipo          String // "pagar" ou "receber"
  descricao     String
  valor         Float
  dataVencimento DateTime
  dataPagamento DateTime?
  status        String   @default("pendente") // "pendente", "pago", "atrasado"
  observacoes   String?
  categoria     String?
  dataCriacao   DateTime @default(now())

  @@map("contas")
}

model Agendamento {
  id          Int      @id @default(autoincrement())
  data        DateTime
  horario     String
  servico     String
  observacoes String?
  status      String   @default("agendado") // "agendado", "realizado", "cancelado"
  dataCriacao DateTime @default(now())

  // Chaves estrangeiras
  clienteId     Int
  funcionarioId Int?
  setorId       Int?

  // Relacionamentos
  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  funcionario Funcionario? @relation(fields: [funcionarioId], references: [id])
  setor       Setor?       @relation(fields: [setorId], references: [id])

  @@map("agendamentos")
}

model Configuracao {
  id           Int      @id @default(autoincrement())
  chave        String   @unique
  valor        String
  descricao    String?
  dataAlteracao DateTime @default(now())

  @@map("configuracoes")
}
